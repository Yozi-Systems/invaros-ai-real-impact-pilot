{
  "name": "invaros-openclaw-interception-probe",
  "version": "0.0.0-review-only",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --external:openclaw/* --outfile=dist/index.js && esbuild protocol.ts ipc-client.ts --platform=node --format=esm --outdir=dist",
    "test": "node --test tests/*.test.mjs"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "DEPLOYMENT_RUNBOOK.md",
    "CHANGELOG.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "2026.6.10",
      "minGatewayVersion": "2026.6.10"
    },
    "build": {
      "openclawVersion": "2026.6.10",
      "pluginSdkVersion": "2026.6.10"
    }
  },
  "devDependencies": {
    "esbuild": "^0.25.6"
  }
}
