{
  "id": "invaros-interception-probe",
  "name": "InvarOS Interception Probe",
  "description": "Review-only DENY/ALLOW pre-execution probe for OpenClaw 2026.6.10",
  "contracts": {
    "tools": [
      "invaros_probe_touch"
    ]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["socketPath", "timeoutMs"],
    "properties": {
      "socketPath": {
        "type": "string",
        "default": "/run/invarosd/openclaw-authorize.sock",
        "const": "/run/invarosd/openclaw-authorize.sock"
      },
      "timeoutMs": {
        "type": "integer",
        "default": 1000,
        "const": 1000
      }
    }
  }
}
